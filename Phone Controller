--//========================
--// Page Navigation
--//========================
local currentPage  = "HOME"
local transitioning = false

local function gotoPage(pageName)
	if transitioning or pageName == currentPage then return end
	transitioning = true

	local toHome = (pageName == "HOME")
	local hPos = toHome and UDim2.fromScale(0, 0)  or UDim2.fromScale(-1, 0)
	local mPos = toHome and UDim2.fromScale(1, 0)  or UDim2.fromScale(0, 0)

	local t1 = quickTween(HomePage,     CONFIG.PAGE_TWEEN, {Position = hPos})
	local t2 = quickTween(MessagesPage, CONFIG.PAGE_TWEEN, {Position = mPos})
	t2.Completed:Wait()

	currentPage   = pageName
	transitioning = false
end

