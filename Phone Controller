-- ============================================================
-- Signal dispatch
-- ============================================================
local function processSignal(sender: Player, action: string)
	local key = ("%d:%s"):format(sender.UserId, action)
	local now = os.clock()
	if lastSignalByKey[key] and (now - lastSignalByKey[key] < CONFIG.SIGNAL_DEBOUNCE) then
		return
	end
	lastSignalByKey[key] = now

	if action == "HELP" then
		addFeed(("%s sent: Help me!"):format(sender.Name),        Color3.fromRGB(255, 165, 165))
		applyHelpFx(sender)

	elseif action == "FOLLOW" then
		addFeed(("%s sent: Follow me!"):format(sender.Name),      Color3.fromRGB(255, 224, 120))
		applyFollowFx(sender)   -- gold waypoint, visible to ALL, no range gate

	elseif action == "TEAM" then
		addFeed(("%s sent: Let's team!"):format(sender.Name),     Color3.fromRGB(176, 255, 195))
		applyHighlightFx(sender, CONFIG.COLORS.Success, CONFIG.TEAM_DURATION)

	elseif action == "STOPFOLLOW" then
		addFeed(("%s sent: Stop following!"):format(sender.Name), Color3.fromRGB(210, 160, 255))
		clearFx(sender.UserId)  -- removes every active fx on that player
	end
end

--//========================
--// Animator hooks
--//========================
local function getAnimatorFromPlayer(plr: Player)
	local char = plr.Character
	if not char then return nil end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end
	return hum:FindFirstChildOfClass("Animator")
end

local function hookAnimator(plr: Player, animator: Animator)
	if hookedAnimators[animator] then return end
	hookedAnimators[animator] = true

	animator.AnimationPlayed:Connect(function(track)
		local anim = track and track.Animation
		if not anim then return end
		local action = ActionByAnim[nAnimId(anim.AnimationId)]
		if action then
			processSignal(plr, action)
		end
	end)
end

local function hookPlayer(plr: Player)
	local charAddedConn
	local ancestryConn

	local function tryHook()
		local animator = getAnimatorFromPlayer(plr)
		if animator then
			hookAnimator(plr, animator)
		end
	end

	tryHook()

	charAddedConn = plr.CharacterAdded:Connect(function()
		task.wait(CONFIG.PLAYER_REHOOK_DELAY)
		tryHook()
	end)

	ancestryConn = plr.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			clearFx(plr.UserId)
		end
	end)

	playerConnections[plr] = {charAddedConn, ancestryConn}
end

local function unhookPlayer(plr: Player)
	clearFx(plr.UserId)
	local list = playerConnections[plr]
	if list then
		for _, c in ipairs(list) do
			if typeof(c) == "RBXScriptConnection" then
				c:Disconnect()
			end
		end
	end
	playerConnections[plr] = nil
end

for _, p in ipairs(Players:GetPlayers()) do
	hookPlayer(p)
end
Players.PlayerAdded:Connect(hookPlayer)
Players.PlayerRemoving:Connect(unhookPlayer)

--//========================
--// Local action triggers
--//========================
local function localAnimator(): Animator?
	local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	if not char then return nil end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end
	return hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
end

local function playActionAnimation(action: string)
	if not animationConfigured(action) then
		safeNotify("Phone", ("Animation ID missing for %s"):format(action), 2)
		addFeed(("Failed to send %s: animation not configured"):format(action), Color3.fromRGB(255, 170, 170))
		return
	end

	local animId = CONFIG.ANIMATION_IDS[action]
	local animator = localAnimator()
	if not animator then
		safeNotify("Phone", "No Animator found.", 2)
		return
	end

	local anim  = Instance.new("Animation")
	anim.AnimationId = animId
	local ok, track = pcall(function()
		return animator:LoadAnimation(anim)
	end)
	if not ok or not track then
		safeNotify("Phone", "Could not load animation.", 2)
		return
	end

	track.Priority = Enum.AnimationPriority.Action
	track:Play(0.1, 1, 1)

	-- local echo (real signal still comes from detection)
	if action == "HELP" then
		addFeed("You sent: Help me! (animation played)",        Color3.fromRGB(255, 170, 170))
	elseif action == "FOLLOW" then
		addFeed("You sent: Follow me! (animation played)",      Color3.fromRGB(255, 230, 100))
	elseif action == "TEAM" then
		addFeed("You sent: Let's team! (animation played)",     Color3.fromRGB(180, 255, 200))
	elseif action == "STOPFOLLOW" then
		addFeed("You sent: Stop following! (animation played)", Color3.fromRGB(210, 165, 255))
	end
end

