--//========================
--// Helpers
--//========================
local function safeNotify(title, text, duration)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = title or "Phone",
			Text  = text or "",
			Duration = duration or 2
		})
	end)
end

local function nAnimId(animId: string): string
	local n = tostring(animId or ""):match("%d+")
	return n or ""
end

local function lerpColor(a: Color3, b: Color3, t: number): Color3
	return a:Lerp(b, math.clamp(t, 0, 1))
end

local function quickTween(obj, info, props)
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function makeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function makeStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color        = color
	s.Thickness    = thickness or 1
	s.Transparency = transparency or 0
	s.Parent       = parent
	return s
end

local function formatClock()
	local dt = DateTime.now():ToLocalTime()
	local h    = dt.Hour
	local m    = dt.Minute
	local ampm = "AM"
	if h >= 12 then ampm = "PM" end
	if h == 0 then h = 12 elseif h > 12 then h = h - 12 end
	return string.format("%d:%02d %s", h, m, ampm)
end

--//========================
--// Validation
--//========================
local ActionByAnim = {}
do
	local seen = {}
	for action, id in pairs(CONFIG.ANIMATION_IDS) do
		local n = nAnimId(id)
		if n ~= "" and n ~= "0" then
			if seen[n] then
				warn(("[ Phone] Duplicate animation ID for %s and %s. Use unique IDs."):format(seen[n], action))
			end
			seen[n] = action
			ActionByAnim[n] = action
		end
	end
end

local function animationConfigured(action: string): boolean
	local id = CONFIG.ANIMATION_IDS[action]
	local n   = nAnimId(id)
	return n ~= "" and n ~= "0"
end

