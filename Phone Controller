	if not c then return nil end
	return c:FindFirstChild("HumanoidRootPart")
end

-- Red HELP waypoint
local function applyHelpFx(sender: Player)
	local char = sender.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end

	clearFx(sender.UserId)

	local bill = Instance.new("BillboardGui")
	bill.Name        = "PhoneHelpWaypoint"
	bill.Adornee     = head
	bill.Size        = UDim2.fromOffset(240, 84)
	bill.StudsOffset = Vector3.new(0, 8, 0)
	bill.MaxDistance = 10000
	bill.AlwaysOnTop = true
	bill.LightInfluence = 0
	bill.Parent      = char

	local bg = Instance.new("Frame")
	bg.Size               = UDim2.fromScale(1, 1)
	bg.BackgroundColor3   = CONFIG.COLORS.Danger
	bg.BackgroundTransparency = 0.12
	bg.Parent             = bill
	makeCorner(bg, 12)
	makeStroke(bg, Color3.fromRGB(255, 255, 255), 1, 0.5)

	local txt = Instance.new("TextLabel")
	txt.Size               = UDim2.fromScale(1, 1)
	txt.BackgroundTransparency = 1
	txt.Text               = "HELP!"
	txt.Font               = Enum.Font.GothamBlack
	txt.TextScaled         = true
	txt.TextColor3         = Color3.fromRGB(255, 255, 255)
	txt.Parent             = bg

	local arrow = Instance.new("Frame")
	arrow.Size            = UDim2.fromOffset(26, 26)
	arrow.Position        = UDim2.new(0.5, -13, 1, -2)
	arrow.Rotation        = 45
	arrow.BackgroundColor3 = CONFIG.COLORS.Danger
	arrow.BackgroundTransparency = 0.12
	arrow.Parent          = bg

	activeFx[sender.UserId] = activeFx[sender.UserId] or {}
	activeFx[sender.UserId].billboard = bill

	task.spawn(function()
		local t0 = os.clock()
		while bill.Parent and (os.clock() - t0) < CONFIG.HELP_DURATION do
			local dt = os.clock() - t0
			bg.BackgroundTransparency    = 0.08 + (math.sin(dt * 8) + 1) * 0.18
			arrow.BackgroundTransparency = bg.BackgroundTransparency
			bill.StudsOffset             = Vector3.new(0, 8 + math.sin(dt * 3) * 0.15, 0)
			RunService.Heartbeat:Wait()
		end
		if bill.Parent then bill:Destroy() end
		if activeFx[sender.UserId] then activeFx[sender.UserId].billboard = nil end
	end)
end

