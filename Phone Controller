--//========================
--// Phone open/close
--//========================
local phoneOpen       = false
local phoneTweenBusy  = false

local function syncMiniText()
	ToggleMini.Text = phoneOpen and "Close Phone (K)" or "Open Phone (K)"
end

local function setPhoneOpen(state)
	if phoneTweenBusy or phoneOpen == state then return end
	phoneTweenBusy = true
	phoneOpen      = state

	local pTarget = state and CONFIG.PHONE_ONSCREEN_POS or CONFIG.PHONE_OFFSCREEN_POS
	local sTarget = pTarget + UDim2.fromOffset(10, 10)

	local pTween = quickTween(Phone, state and CONFIG.OPEN_TWEEN or CONFIG.CLOSE_TWEEN, {Position = pTarget})
	quickTween(PhoneShadow, state and CONFIG.OPEN_TWEEN or CONFIG.CLOSE_TWEEN, {
		Position         = sTarget,
		ImageTransparency = state and 0.55 or 0.75
	})

	pTween.Completed:Wait()
	phoneTweenBusy = false
	syncMiniText()
end

ToggleMini.MouseButton1Click:Connect(function()
	setPhoneOpen(not phoneOpen)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if UserInputService:GetFocusedTextBox() then return end
	if input.KeyCode == CONFIG.KEYBIND then
		setPhoneOpen(not phoneOpen)
	end
end)

