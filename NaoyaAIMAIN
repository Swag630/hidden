-- VirtualInputManager — works in executor scripts.
-- ═══════════════════════════════════════════════════════════

local function keyDown(kc)
    pcall(function() VIM:SendKeyEvent(true, kc, false, game) end)
end

local function keyUp(kc)
    pcall(function() VIM:SendKeyEvent(false, kc, false, game) end)
end

local function tapKey(kc, holdDur)
    holdDur = holdDur or 0.08
    keyDown(kc)
    task.delay(holdDur, function() keyUp(kc) end)
end

local function tapLMB()
    pcall(function()
        local vp = workspace.CurrentCamera.ViewportSize
        local cx = vp.X * 0.5
        local cy = vp.Y * 0.5
        VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.delay(0.06, function()
            VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
        end)
    end)
end

local function triggerJump()
    if humanoid then humanoid.Jump = true end
end

-- ═══════════════════════════════════════════════════════════
-- TARGETING SYSTEM
-- getNearest() — combat target (skips blacklisted + follow-mode players)
-- ═══════════════════════════════════════════════════════════

local function getNearest()
    if not rootPart then return nil, math.huge end
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        -- Skip self, blacklisted players, AND players we're currently shadowing
        if p ~= player and p.Character and not blacklist[p] and not followMode[p] then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 then
                local d = (rootPart.Position - r.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    best     = p.Character
                end
            end
        end
    end
    return best, bestDist
end

local function getEnemyRoot(target)
    if not target then return nil end
    return target:FindFirstChild("HumanoidRootPart")
end

local function distanceTo(target)
    if not target or not rootPart then return math.huge end
    local r = getEnemyRoot(target)
    if not r then return math.huge end
    return (rootPart.Position - r.Position).Magnitude
end

local function faceToward(target)
    if not rootPart or not target then return end
    local r = getEnemyRoot(target)
    if not r then return end
    local dx = r.Position.X - rootPart.Position.X
    local dz = r.Position.Z - rootPart.Position.Z
    local flat = Vector3.new(dx, 0, dz)
    if flat.Magnitude > 0.05 then
        rootPart.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + flat.Unit)
    end
end

-- ═══════════════════════════════════════════════════════════
-- MOVEMENT SYSTEM
-- WalkToPoint updated every Heartbeat.
-- Follow mode overrides normal chase — positions AI exactly
-- FOLLOW_BEHIND_DIST studs behind the follow target's back.
-- ═══════════════════════════════════════════════════════════

local moveTarget = nil  -- Vector3 or nil

RunService.Heartbeat:Connect(function()
    if not humanoid or humanoid.Health <= 0 then return end
    if moveTarget then
        humanoid.WalkToPoint = moveTarget
    end
end)

local function pushTowardEnemy()
    local t, _ = getNearest()
    if not t then return end
    local r = getEnemyRoot(t)
    if r and rootPart then
        faceToward(t)
        moveTarget = r.Position
    end
end

local function plantFeet()
    moveTarget = nil
    if humanoid and rootPart then
        humanoid.WalkToPoint = rootPart.Position
    end
end

-- Computes the position 4 studs directly behind a character's back.
-- "Behind" = opposite of the character's CFrame LookVector, on the XZ plane.
local function behindPosition(targetRoot)
    if not targetRoot then return nil end
    local look  = targetRoot.CFrame.LookVector
    local flatLook = Vector3.new(look.X, 0, look.Z)
    if flatLook.Magnitude < 0.001 then
        flatLook = Vector3.new(0, 0, 1)
    end
    flatLook = flatLook.Unit
    -- Position is directly behind: subtract look direction
    return targetRoot.Position - flatLook * FOLLOW_BEHIND_DIST
end

-- ═══════════════════════════════════════════════════════════
-- WANDER SYSTEM
-- ═══════════════════════════════════════════════════════════

local wanderAngle     = 0
local wanderChangeAt  = 0

local function doWander()
    local now = tick()
    if now > wanderChangeAt then
        wanderAngle    = math.random() * math.pi * 2
        wanderChangeAt = now + WANDER_INTERVAL + math.random() * 1.5
        if math.random() < 0.15 then
            task.delay(0.1, function() triggerJump() end)
        end
    end
    if rootPart then
        local origin = rootPart.Position
        local dest = origin + Vector3.new(
            math.sin(wanderAngle) * WANDER_DIST,
            0,
            math.cos(wanderAngle) * WANDER_DIST
        )
        moveTarget = dest
    end
end

-- ═══════════════════════════════════════════════════════════
-- COMBO STATE
-- ═══════════════════════════════════════════════════════════

busy   = false   -- true while a combo is executing (global so follow-mode abort can set it)
killed = false   -- set true on death or follow-mode interrupt to abort combo

local function isAlive()
    return humanoid ~= nil
        and humanoid.Health > 0
        and not killed
end

local function endCombo()
    busy = false
end

-- ═══════════════════════════════════════════════════════════
-- ATOMIC ACTIONS
-- ═══════════════════════════════════════════════════════════

local function doOneLMB(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    tapLMB()
    task.delay(M1_GAP, function()
        if onDone then onDone() end
    end)
end

local function doM1Chain(n, onDone)
    if not isAlive() then endCombo(); return end
    local fired = 0
    local function step()
        if not isAlive() then endCombo(); return end
        if fired >= n then
            if onDone then onDone() end
            return
        end
        fired = fired + 1
        pushTowardEnemy()
        print(string.format("[AI] M1 %d/%d", fired, n))
        tapLMB()
        task.delay(M1_GAP, step)
    end
    step()
end

local function doSkill3Spam(times, onDone)
    if not isAlive() then endCombo(); return end
    cdUse("s3")
    local fired = 0
    local function step()
        if not isAlive() then endCombo(); return end
        if fired >= times then
            if onDone then onDone() end
            return
        end
        fired = fired + 1
        pushTowardEnemy()
        print(string.format("[AI] Skill 3 spam %d/%d", fired, times))
        tapKey(Enum.KeyCode.Three, 0.08)
        task.delay(SKILL_GAP, step)
    end
    step()
end

local function doSkill2(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    local _, dist = getNearest()
    print(string.format("[AI] Skill 2 — Bleedout extender (%.1f studs)", dist))
    tapKey(Enum.KeyCode.Two, 0.08)
    cdUse("s2")
    task.delay(COMBO_GAP + 0.1, function()
        if onDone then onDone() end
    end)
end

local function doSkill4(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    local _, dist = getNearest()
    print(string.format("[AI] Skill 4 — Cursory Impact ender (%.1f studs)", dist))
    tapKey(Enum.KeyCode.Four, 0.08)
    cdUse("s4")
    task.delay(0.18, function()
        if onDone then onDone() end
    end)
end

local function doSkill1(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    local _, dist = getNearest()
    print(string.format("[AI] Skill 1 — Projection Breaker ender (%.1f studs)", dist))
    tapKey(Enum.KeyCode.One, 0.08)
    cdUse("s1")
    task.delay(0.18, function()
