-- ═══════════════════════════════════════════════════════════
-- SHARED ANIMATION HELPER
-- Checks whether a character is currently playing a given
-- animation ID (matched by the trailing numeric ID).
-- Used by both the blacklist and follow-mode systems.
-- ═══════════════════════════════════════════════════════════

local function isPlayingAnimId(char, animIdStr)
    local animator = char:FindFirstChildOfClass("Animator")
        or (char:FindFirstChildOfClass("Humanoid")
        and char:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator"))
    if not animator then return false end
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
        local id = tostring(track.Animation.AnimationId):match("%d+$")
        if id == animIdStr then return true end
    end
    return false
end

-- ═══════════════════════════════════════════════════════════
-- BLACKLIST SYSTEM
-- If a player plays animation 78450002510885 within 15 studs,
-- ignore them entirely for the rest of the match.
-- ═══════════════════════════════════════════════════════════

local blacklist            = {}       -- [Player] = true when blacklisted
local BLACKLIST_ANIM_ID    = "78450002510885"
local BLACKLIST_RANGE      = 15000       -- studs — only blacklist if within this distance

-- ═══════════════════════════════════════════════════════════
-- FOLLOW MODE SYSTEM
-- Animation 70683985130739 → enter follow mode:
--   stop all attacks, move to 4 studs directly behind
--   the target's back (opposite of their LookVector).
-- Animation 93265997037616 → exit follow mode:
--   resume normal free combat immediately.
-- ═══════════════════════════════════════════════════════════

local followMode          = {}        -- [Player] = true when AI must shadow them
local FOLLOW_ANIM_ID      = "70683985130739"
local STOP_FOLLOW_ANIM_ID = "93265997037616"
local FOLLOW_BEHIND_DIST  = 4         -- studs behind the target's back

-- Returns the current follow-mode target (first found), or nil.
local function getFollowTarget()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and followMode[p] then
            if p.Character then
                local h = p.Character:FindFirstChildOfClass("Humanoid")
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and h and h.Health > 0 then
                    return p, p.Character
                end
            end
            -- Character gone — clear stale entry
            followMode[p] = nil
        end
    end
    return nil, nil
end

-- Runs every frame — handles all per-player animation state transitions
RunService.Heartbeat:Connect(function()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 then

                -- ── BLACKLIST logic ─────────────────────────────────
                if not blacklist[p] and rootPart then
                    local dist = (rootPart.Position - r.Position).Magnitude
                    if dist <= BLACKLIST_RANGE and isPlayingAnimId(p.Character, BLACKLIST_ANIM_ID) then
                        blacklist[p] = true
                        print("[AI] " .. p.Name .. " blacklisted — dodge anim within " .. BLACKLIST_RANGE .. " studs")
                    end
                end

                -- ── FOLLOW MODE logic ────────────────────────────────
                if not followMode[p] then
                    -- Enter follow mode if the trigger animation is detected
                    if isPlayingAnimId(p.Character, FOLLOW_ANIM_ID) then
                        followMode[p] = true
                        -- Abort any running combo immediately so we stop attacking
                        busy   = true   -- prevent new combos from starting
                        killed = true   -- signal running combo chains to abort
                        task.delay(0.05, function()
                            -- Reset flags after brief pause so follow loop can run cleanly
                            busy   = false
                            killed = false
                        end)
                        print("[AI] FOLLOW MODE ON — shadowing " .. p.Name .. " (anim 70683985130739)")
                    end
                else
                    -- Exit follow mode if the release animation is detected
                    if isPlayingAnimId(p.Character, STOP_FOLLOW_ANIM_ID) then
                        followMode[p] = nil
                        print("[AI] FOLLOW MODE OFF — resuming combat on " .. p.Name .. " (anim 93265997037616)")
                    end
                end

            else
                -- Dead or gone — clear both states
                blacklist[p]  = nil
                followMode[p] = nil
            end
        end
    end
end)

-- ═══════════════════════════════════════════════════════════
-- COOLDOWN SYSTEM
-- ═══════════════════════════════════════════════════════════

local timers = { r=0, q=0, s1=0, s2=0, s3=0, s4=0, g=0 }
local cdValues = { r=CD_R, q=CD_Q, s1=CD_S1, s2=CD_S2, s3=CD_S3, s4=CD_S4, g=CD_G }

local dashCharges = DASH_MAX_CHARGES
local dashResetAt = 0

local function cdReady(k)
    return timers[k] <= 0
end

local function cdUse(k)
    timers[k] = cdValues[k]
end

local function cdForceReady(k)
    timers[k] = 0
end

local function cdTickAll(dt)
    for k in pairs(timers) do
        timers[k] = math.max(0, timers[k] - dt)
    end
end

local function dashAvailable()
    if tick() - dashResetAt >= CD_Q then
        dashCharges = DASH_MAX_CHARGES
        dashResetAt = tick()
    end
    return dashCharges > 0
end

local function useDashCharge()
    if dashAvailable() then
        dashCharges = dashCharges - 1
        return true
    end
    return false
end

local function allOffensiveOnCD()
    return not cdReady("s1") and not cdReady("s2")
       and not cdReady("s3") and not cdReady("s4")
end

