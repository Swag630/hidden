    if inp.KeyCode == Enum.KeyCode.P and UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
        aiEnabled = not aiEnabled
        if not aiEnabled then
            killed = true
            busy   = false
            plantFeet()
            print("[AI] ⛔  STOPPED — Shift+P to resume")
        else
            killed    = false
            busy      = false
            aiEnabled = true
            print("[AI] ✅  RESUMED")
        end
    end
end)

