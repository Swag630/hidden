-- DEATH HANDLING
-- ═══════════════════════════════════════════════════════════

local function onDeath()
    killed = true
    busy   = false
    plantFeet()
    print("[AI] Character died — combo aborted")
end

humanoid.Died:Connect(onDeath)

player.CharacterAdded:Connect(function(c)
    task.wait(0.1)
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Died:Connect(onDeath)
        killed = false
        busy   = false
    end
end)

