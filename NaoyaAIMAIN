    end)
end

local function doEnder(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    if cdReady("s4") then
        doSkill4(onDone)
    elseif cdReady("s1") then
        doSkill1(onDone)
    else
        print("[AI] Enders on CD — capping with M1")
        tapLMB()
        task.delay(M1_GAP, function()
            if onDone then onDone() end
        end)
    end
end

local function doQDash(onDone)
    if not isAlive() then endCombo(); return end
    local t, _ = getNearest()
    if t then faceToward(t) end
    if dashAvailable() then
        pushTowardEnemy()
        print("[AI] Q dash → chasing")
        tapKey(Enum.KeyCode.Q, 0.08)
        useDashCharge()
    else
        print("[AI] Q on CD — skipping dash")
    end
    task.delay(DASH_GAP, function()
        if onDone then onDone() end
    end)
end

local function doDoubleQDash(onDone)
    if not isAlive() then endCombo(); return end
    local t1, _ = getNearest()
    if t1 then faceToward(t1) end
    pushTowardEnemy()
    print("[AI] Q dash #1 (post-2 chase)")
    tapKey(Enum.KeyCode.Q, 0.08)
    useDashCharge()

    task.delay(DASH_GAP, function()
        if not isAlive() then endCombo(); return end
        local t2, _ = getNearest()
        if t2 then faceToward(t2) end
        pushTowardEnemy()
        print("[AI] Q dash #2 (post-2 chase)")
        tapKey(Enum.KeyCode.Q, 0.08)
        useDashCharge()
        task.delay(DASH_GAP, function()
            if onDone then onDone() end
        end)
    end)
end

local function doTeleport(onDone)
    if not isAlive() then endCombo(); return end
    local t, _ = getNearest()
    if t then faceToward(t) end
    print("[AI] R — Teleport")
    tapKey(Enum.KeyCode.R, 0.08)
    cdUse("r")
    task.delay(0.38, function()
        if onDone then onDone() end
    end)
end

local function doUltimate(onDone)
    if not isAlive() then endCombo(); return end
    pushTowardEnemy()
    print("[AI] ★ ULTIMATE — G → jump → 1 ★")
    tapKey(Enum.KeyCode.G, 0.08)
    cdUse("g")
    task.delay(0.38, function()
        if not isAlive() then endCombo(); return end
        triggerJump()
        task.delay(0.32, function()
            if not isAlive() then endCombo(); return end
            print("[AI] Ultimate followup: 1")
            tapKey(Enum.KeyCode.One, 0.08)
            cdUse("s1")
            task.delay(0.2, function()
                if onDone then onDone() end
            end)
        end)
    end)
end

-- ═══════════════════════════════════════════════════════════
-- COMBO SEQUENCES
-- ═══════════════════════════════════════════════════════════

local function runFullCombo()
    if busy then return end
    busy   = true
    killed = false
    print("[AI] ══════════ FULL COMBO START ══════════")

    doSkill3Spam(3, function()
        if not isAlive() then endCombo(); return end
        doM1Chain(3, function()
            if not isAlive() then endCombo(); return end
            if cdReady("s2") then
                doSkill2(function()
                    if not isAlive() then endCombo(); return end
                    doDoubleQDash(function()
                        if not isAlive() then endCombo(); return end
                        doM1Chain(3, function()
                            if not isAlive() then endCombo(); return end
                            doEnder(function()
                                print("[AI] ══════════ FULL COMBO END ══════════")
                                endCombo()
                            end)
                        end)
                    end)
                end)
            else
                print("[AI] Skill 2 on CD — truncating to short combo")
                doEnder(function()
                    print("[AI] ══════════ TRUNCATED COMBO END ══════════")
                    endCombo()
                end)
            end
        end)
    end)
end

local function runShortCombo()
    if busy then return end
    busy   = true
    killed = false
    local m1count = math.random(3, 4)
    print(string.format("[AI] ══════════ SHORT COMBO ×%d START ══════════", m1count))

    doSkill3Spam(3, function()
        if not isAlive() then endCombo(); return end
        doM1Chain(m1count, function()
            if not isAlive() then endCombo(); return end
            if cdReady("s2") and m1count == 3 then
                print("[AI] 2 came off CD mid-short — using as extender!")
                doSkill2(function()
                    if not isAlive() then endCombo(); return end
                    doDoubleQDash(function()
                        if not isAlive() then endCombo(); return end
                        doM1Chain(3, function()
                            if not isAlive() then endCombo(); return end
                            doEnder(function()
                                print("[AI] ══════════ SHORT→FULL COMBO END ══════════")
                                endCombo()
                            end)
                        end)
                    end)
                end)
            else
                doEnder(function()
                    print("[AI] ══════════ SHORT COMBO END ══════════")
                    endCombo()
                end)
            end
        end)
    end)
end

local function runCloseCombo()
    if busy then return end
    busy   = true
    killed = false
    print("[AI] ══════════ CLOSE COMBO START ══════════")

    doM1Chain(3, function()
        if not isAlive() then endCombo(); return end
        if cdReady("s2") then
            doSkill2(function()
                if not isAlive() then endCombo(); return end
