        else
            print("[AI] Skill 2 on CD — close short finisher")
            doEnder(function()
                print("[AI] ══════════ CLOSE SHORT COMBO END ══════════")
                endCombo()
            end)
        end
    end)
end

local function runDumpCombo()
    if busy then return end
    busy   = true
    killed = false
    print("[AI] ══════════ DUMP COMBO M1×4 ══════════")
    doM1Chain(4, function()
        print("[AI] ══════════ DUMP COMBO END ══════════")
        endCombo()
    end)
end

local function runUltimate()
    if busy then return end
    busy   = true
    killed = false
    doUltimate(function()
        print("[AI] ══════════ ULTIMATE END ══════════")
        endCombo()
    end)
end

local function runTeleport()
    if busy then return end
    busy = true
    doTeleport(function() endCombo() end)
end

local function runQDash(target)
    if busy then return end
    if not dashAvailable() then return end
    busy = true
    if target then faceToward(target) end
    doQDash(function() endCombo() end)
end

-- ═══════════════════════════════════════════════════════════
-- SITUATION CLASSIFIER
-- ═══════════════════════════════════════════════════════════

local SIT = {
    FAR         = "far",
    MEDIUM_FAR  = "medium_far",
    MEDIUM      = "medium",
    ATTACK      = "attack",
    CLOSE       = "close",
}

local function classify(dist)
    if dist > RANGE_TELEPORT  then return SIT.FAR         end
    if dist > RANGE_SKILL3    then return SIT.MEDIUM_FAR  end
    if dist > RANGE_M1        then return SIT.MEDIUM      end
    if dist > RANGE_CLOSE     then return SIT.ATTACK      end
    return SIT.CLOSE
end

-- ═══════════════════════════════════════════════════════════
-- SKILL 2 AGGRESSIVE USE
-- ═══════════════════════════════════════════════════════════

local skill2UsedAt = 0
local function shouldUseSkill2Standalone(dist)
    return cdReady("s2")
        and dist <= RANGE_SKILL2
        and (tick() - skill2UsedAt) > CD_S2 * 0.9
end

-- ═══════════════════════════════════════════════════════════
-- MAIN DECISION LOOP
-- ═══════════════════════════════════════════════════════════

local aiEnabled  = true
local thinkTimer = 0

RunService.Heartbeat:Connect(function(dt)
    if not aiEnabled then return end
    if not humanoid or humanoid.Health <= 0 then return end

    cdTickAll(dt)

    -- ── FOLLOW MODE MOVEMENT (highest priority, every frame) ──
    -- If any player is in follow mode, shadow them — no combat.
    local followPlayer, followChar = getFollowTarget()
    if followPlayer and followChar then
        local followRoot = followChar:FindFirstChild("HumanoidRootPart")
        if followRoot and rootPart then
            local dest = behindPosition(followRoot)
            if dest then
                moveTarget = dest
                -- Face the same direction the target is facing
                -- (walk alongside them, looking the same way)
                local look  = followRoot.CFrame.LookVector
                local flatLook = Vector3.new(look.X, 0, look.Z)
                if flatLook.Magnitude > 0.05 then
                    rootPart.CFrame = CFrame.lookAt(
                        rootPart.Position,
                        rootPart.Position + flatLook.Unit
                    )
                end
            end
        end
        -- Do NOT fall through to combat decisions
        return
    end

    -- ── NORMAL MOVEMENT (every frame) ─────────────────────────
    local mt, md = getNearest()
    if mt then
        local mr = getEnemyRoot(mt)
        if mr then
            faceToward(mt)
            if md > 3 then
                moveTarget = mr.Position
            end
        end
    else
        doWander()
    end

    -- ── DECISIONS (throttled) ──────────────────────────────────
    thinkTimer = thinkTimer + dt
    if thinkTimer < THINK_RATE then return end
    thinkTimer = 0

    if busy then return end

    local target, dist = getNearest()
    if not target then return end

    faceToward(target)

    local hpPct = humanoid.Health / humanoid.MaxHealth
    local sit   = classify(dist)

    -- PRIORITY 1: Ultimate
    if hpPct < ULT_HP_THRESHOLD and cdReady("g") and dist < 25 then
        print(string.format("[AI] LOW HP (%.0f%%) — ULTIMATE", hpPct * 100))
        runUltimate()
        return
    end

    -- PRIORITY 2: Opportunistic skill 2
    if shouldUseSkill2Standalone(dist) and not busy then
        print("[AI] Opportunistic skill 2!")
        busy = true
        killed = false
        skill2UsedAt = tick()
        doSkill2(function() endCombo() end)
        return
    end

    -- FAR
    if sit == SIT.FAR then
        if cdReady("r") then
            runTeleport()
        elseif dashAvailable() then
            runQDash(target)
        end
        return
    end

    -- MEDIUM FAR
    if sit == SIT.MEDIUM_FAR then
        if cdReady("r") then
            runTeleport()
        elseif dashAvailable() then
            runQDash(target)
        end
        return
    end

    -- MEDIUM
    if sit == SIT.MEDIUM then
        if dashAvailable() and dist > 8 then
            runQDash(target)
            return
        end
        if allOffensiveOnCD() then return end
        if cdReady("s2") then
            runFullCombo()
        else
            runShortCombo()
        end
        return
    end

    -- ATTACK RANGE
    if sit == SIT.ATTACK then
        if allOffensiveOnCD() then
            runDumpCombo()
            return
        end
        if cdReady("s2") then
            runFullCombo()
        else
            runShortCombo()
        end
        return
    end

    -- CLOSE RANGE
    if sit == SIT.CLOSE then
        if allOffensiveOnCD() then
            runDumpCombo()
            return
        end
        runCloseCombo()
        return
    end
end)

