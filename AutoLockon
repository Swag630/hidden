end)


-- ─── STATUS LABELS ───────────────────────────────────────────────────────────

local function updateStatusLabels()
    if not scriptEnabled then
        lockStatusVal.Text = "OFFLINE"
        lockStatusVal.TextColor3 = Color3.fromRGB(80, 80, 80)
        targetVal.Text = "---"
        targetVal.TextColor3 = Color3.fromRGB(80, 80, 80)
        dodgeVal.Text = "---"
        dodgeVal.TextColor3 = Color3.fromRGB(80, 80, 80)
        return
    end

    if locked and target then
        lockStatusVal.Text = "LOCKED"
        lockStatusVal.TextColor3 = Color3.fromRGB(255, 60, 60)
    else
        lockStatusVal.Text = "SEARCHING"
        lockStatusVal.TextColor3 = Color3.fromRGB(200, 160, 40)
    end

    if target then
        local name = target.Name
        if #name > 10 then name = string.sub(name, 1, 9) .. "…" end
        targetVal.Text = name
        targetVal.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        targetVal.Text = "NONE"
        targetVal.TextColor3 = Color3.fromRGB(80, 80, 80)
    end

    if isDodging then
        dodgeVal.Text = string.format("EVADING %.1fs", dodgeTimer)
        dodgeVal.TextColor3 = Color3.fromRGB(255, 200, 40)
    else
        dodgeVal.Text = "TRACKING"
        dodgeVal.TextColor3 = Color3.fromRGB(60, 200, 100)
    end
end


-- ─── HELPERS ─────────────────────────────────────────────────────────────────

local function simulateLeftClick()
    mouse1click()
end

local function getAnimator(character)
    local hum = character:FindFirstChildOfClass("Humanoid")
    if hum then
        local anim = hum:FindFirstChildOfClass("Animator")
        if anim then return anim end
    end
    return character:FindFirstChildOfClass("Animator")
end

local function isPlayingAnimation(character, animId)
    local animator = getAnimator(character)
    if not animator then return false end
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
        local id = tostring(track.Animation.AnimationId):match("%d+$")
        if id == animId then return true end
    end
    return false
end

local function getPlayingAnimationDodgeDuration(character)
    local animator = getAnimator(character)
    if not animator then return nil end
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
        local id = tostring(track.Animation.AnimationId):match("%d+$")
        if id and DODGE_ANIMATIONS[id] then
            return DODGE_ANIMATIONS[id]
        end
    end
    return nil
end

-- Returns the closest non-blacklisted enemy player, or nil.
local function findClosestTarget()
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local closestDist = math.huge
    local closestPlr = nil

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not blacklisted[plr] then
            local char = plr.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - myHRP.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestPlr = plr
                end
            end
        end
    end

    return closestPlr
end


-- ─── MAIN LOOP ───────────────────────────────────────────────────────────────

RunService.RenderStepped:Connect(function(dt)
    updateStatusLabels()
    if not scriptEnabled then return end

    -- Clean up blacklist entries for players whose character no longer exists
    for plr in pairs(blacklisted) do
        if not plr.Character then
            blacklisted[plr] = nil
        end
    end

    -- ── Scan all players for LOCK_ANIM_ID; force lock onto them ──────────────
    if not forcedTarget then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= player then
                local char = plr.Character
                if char and isPlayingAnimation(char, LOCK_ANIM_ID) then
                    forcedTarget = plr
                    -- Reset dodge state so normal tracking resumes on them
                    isDodging = false
                    dodgeTimer = 0
                    dodgeLookTarget = nil
                    break
                end
            end
        end
    end

    -- ── If we have a forced target, check for unlock anim then camera-lock ───
    if forcedTarget then
        local ftChar = forcedTarget.Character
        local ftHRP  = ftChar and ftChar:FindFirstChild("HumanoidRootPart")

        -- Unlock if the release animation plays or character is gone
        if not ftChar or not ftHRP or isPlayingAnimation(ftChar, UNLOCK2_ANIM_ID) then
            forcedTarget = nil
            isDodging    = false
            dodgeTimer   = 0
            dodgeLookTarget = nil
            target = nil
            locked = false
            return
        end

        -- Lock camera onto forced target
        target = forcedTarget
        locked = true
        camera.CFrame = CFrame.new(camera.CFrame.Position, ftHRP.Position)
        return  -- skip normal target selection while forced
    end

    -- ── Normal auto-target logic ──────────────────────────────────────────────
    target = findClosestTarget()
    locked = target ~= nil

    if not locked then
        isDodging = false
        dodgeTimer = 0
        dodgeLookTarget = nil
        return
    end

    local char = target.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        isDodging = false
        dodgeTimer = 0
        dodgeLookTarget = nil
        return
    end

    -- Check if target is performing the unlock/counter animation (within 15 studs)
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if myHRP then
        local dist = (hrp.Position - myHRP.Position).Magnitude
        if dist <= 15000 and isPlayingAnimation(char, UNLOCK_ANIM_ID) then
            blacklisted[target] = true
            target = nil
            locked = false
            isDodging = false
            dodgeTimer = 0
            dodgeLookTarget = nil
            return
        end
    end

    local camPos = camera.CFrame.Position
    local inRange = myHRP and (hrp.Position - myHRP.Position).Magnitude <= DETECT_RADIUS

    -- Handle active dodge evasion
    if isDodging then
        dodgeTimer = dodgeTimer - dt
        camera.CFrame = CFrame.new(camPos, dodgeLookTarget)
        if dodgeTimer <= 0 then
            isDodging = false
            dodgeTimer = 0
            dodgeLookTarget = nil
            simulateLeftClick()
        end
        return
    end

    -- Detect if target is dodging
    if inRange then
        local duration = getPlayingAnimationDodgeDuration(char)
        if duration then
            isDodging = true
            dodgeTimer = duration
            dodgeLookTarget = camPos + (-camera.CFrame.LookVector) * 50
            return
        end
    end

    -- Normal lock-on: aim camera at target
    camera.CFrame = CFrame.new(camPos, hrp.Position)
end)
