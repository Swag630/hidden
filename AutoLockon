-- ─── PULSE ACCENT ────────────────────────────────────────────────────────────

local function pulseAccent()
    local tweenIn = TweenService:Create(outerBorder, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.6})
    local tweenOut = TweenService:Create(outerBorder, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.1})
    tweenIn:Play()
    tweenIn.Completed:Connect(function()
        tweenOut:Play()
        tweenOut.Completed:Connect(pulseAccent)
    end)
end
pulseAccent()


-- ─── TOGGLE ──────────────────────────────────────────────────────────────────

local function setEnabled(state)
    scriptEnabled = state
    if not state then
        locked = false
        target = nil
        isDodging = false
        dodgeTimer = 0
        dodgeLookTarget = nil
        forcedTarget = nil
    end

    toggleStateLabel.Text = state and "ACTIVE" or "OFFLINE"
    toggleStateLabel.TextColor3 = state and Color3.fromRGB(80, 255, 120) or Color3.fromRGB(255, 60, 60)

    TweenService:Create(toggleBgStroke, TweenInfo.new(0.25), {
        Color = state and Color3.fromRGB(255, 40, 40) or Color3.fromRGB(80, 80, 80)
    }):Play()
    TweenService:Create(outerBorder, TweenInfo.new(0.25), {
        Color = state and Color3.fromRGB(255, 60, 60) or Color3.fromRGB(60, 60, 60)
    }):Play()
    TweenService:Create(accentBar, TweenInfo.new(0.25), {
        BackgroundColor3 = state and Color3.fromRGB(255, 45, 45) or Color3.fromRGB(50, 50, 50)
    }):Play()
end

